# txray environment configuration
# Copy to .env and adjust as needed.

# Path to the txray CLI binary used by the web API.
# Inside Docker this is set automatically; leave blank for local dev
# (the web app will fall back to `cargo run -p txray-cli`).
TXRAY_BIN=/usr/local/bin/txray

# Bitcoin data sources. The web layer and the CLI both honor these.
# If the primary source fails, requests fall back to the secondary.
TXRAY_MEMPOOL_API=https://mempool.space/api
TXRAY_ESPLORA_API=https://blockstream.info/api

# Next.js bind address. Override if you're putting txray behind a reverse
# proxy on the same host.
HOSTNAME=0.0.0.0
PORT=3000
